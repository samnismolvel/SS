{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ss",
  "version": "0.1.0",
  "identifier": "com.codespace.ss",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "devTools": true
      },
      {
        "title": "ss",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/ffmpeg",
      "../whisper.cpp/build/bin/whisper-cli",
      "../whisper.cpp/models/ggml-tiny.bin"
    ]
  }
}